# RetainAI environment example.
# Copy this file to `.env` for local scripts, or use the same keys in Docker Compose.

# Ollama runs on your host machine. For local Python use localhost.
# Inside Docker Compose use http://host.docker.internal:11434/api/generate.
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=llama3
OLLAMA_TIMEOUT_SECONDS=20

# Folder where trained artifacts are stored.
RETAINAI_ARTIFACT_DIR=artifacts

# PostgreSQL settings.
# Local Python: POSTGRES_HOST=localhost
# Docker Compose API container: POSTGRES_HOST=db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=retainai
POSTGRES_USER=retainai
POSTGRES_PASSWORD=retainai_password

# Optional API URL for Streamlit UI.
RETAINAI_API_URL=http://localhost:8000
